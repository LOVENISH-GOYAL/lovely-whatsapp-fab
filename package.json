{
  "name": "lovely-whatsapp-fab",
  "version": "1.0.11",
  "description": "A whatsapp chat floating button",
  "readme": "README.md",
  "main": "./src/WhatsappFAB.js",
  "module": "./src/WhatsappFAB.js",
  "browser": "./src/WhatsappFAB.js",
  "types": "types/index.d.ts",
  "sideEffects": [
    "*.css"
  ],
  "exports": {
    ".": {
      "import": "./src/WhatsappFAB.js",
      "require": "./src/WhatsappFAB.js",
      "types": "./types/index.d.ts",
      "default": "./src/WhatsappFAB.js"
    },
    "./web": {
      "import": "./src/WhatsappFAB.web.js",
      "require": "./src/WhatsappFAB.web.js",
      "default": "./src/WhatsappFAB.web.js"
    },
    "./react": {
      "import": "./src/WhatsappFAB.js",
      "require": "./src/WhatsappFAB.js",
      "types": "./types/index.d.ts",
      "default": "./src/WhatsappFAB.js"
    },
    "./styles": "./src/WhatsappFAB.module.css",
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "types",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "babel src -d dist",
    "test": "jest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "whatsapp",
    "fab",
    "button",
    "chat",
    "react",
    "angular",
    "vue",
    "web-component",
    "floating-action-button",
    "framework-agnostic"
  ],
  "author": "Lovenish Goyal",
  "license": "MIT",
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@babel/core": "^7.23.7",
    "@babel/plugin-transform-runtime": "^7.23.7",
    "@babel/preset-env": "^7.23.8",
    "@babel/preset-react": "^7.23.3",
    "@testing-library/jest-dom": "^6.2.0",
    "@testing-library/react": "^14.1.2",
    "babel-eslint": "^10.1.0",
    "babel-jest": "^29.7.0",
    "babel-loader": "^9.1.3",
    "eslint": "^8.56.0",
    "eslint-plugin-react": "^7.33.2",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0"
  },
  "dependencies": {
    "prop-types": "^15.8.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/LOVENISH-GOYAL/lovely-whatsapp-fab"
  }
}
